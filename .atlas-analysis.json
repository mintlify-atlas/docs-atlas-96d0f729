  "keyFeatures": [
    "Policy-as-Code for GitHub Organizations",
    "Multi-level configuration hierarchy (org, suborg, repo)",
    "Branch protection and repository rulesets management",
    "Team and collaborator permissions enforcement",
    "Automated drift prevention via webhooks",
    "Pull request validation with dry-run mode",
    "Custom validation rules",
    "Scheduled sync for configuration enforcement",
    "Repository settings management (visibility, topics, custom properties)",
    "Environment configurations with deployment protection"
  ],
  "publicApiSurface": [
    "Webhook Events: push, repository.created, branch_protection_rule, repository.edited, repository.renamed, pull_request.opened, check_suite.requested, repository_ruleset, member, team, custom_property_values",
    "Settings Plugins: repository, branches, rulesets, teams, collaborators, labels, milestones, autolinks, environments, custom_properties, variables",
    "Configuration Files: .github/settings.yml (org), .github/suborgs/*.yml (suborg), .github/repos/*.yml (repo)",
    "Environment Variables: ADMIN_REPO, CONFIG_PATH, SETTINGS_FILE_PATH, DEPLOYMENT_CONFIG_FILE, CRON, ENABLE_PR_COMMENT, BLOCK_REPO_RENAME_BY_HUMAN",
    "Deployment Targets: Docker, AWS Lambda, Kubernetes, GitHub Actions, Heroku"
  ]
